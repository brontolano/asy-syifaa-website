# ==============================================
# Asy-Syifaa Website Environment Configuration
# Copy file ini jadi .env lalu isi sesuai environment
# ==============================================

# --- App ---
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8081
APP_TIMEZONE=Asia/Jakarta

# --- API Base URLs (dipakai PHP backend) ---
# Untuk Website\Support\ApiClient
ASY_SYIFAA_API_BASE_URL=https://api.asy-syifaa.com
# Untuk fallback submit PPDB (api/auth/register-spmb.php)
ASF_API_BASE_URL=https://erp.asy-syifaa.com
# Untuk URL storage media ERP di galeri detail fallback
ASF_ERP_BASE_URL=https://erp.asy-syifaa.com

# --- Frontend API base (opsional, jika ingin sinkron dari server) ---
# Catatan: assets/js/api-config.js masih punya default sendiri.
ASF_WEB_API_BASE=http://localhost:4000
ASF_WEB_ERP_BASE=http://localhost:3000

# --- Integrasi TV / Social (opsional) ---
ASF_YT_API_KEY=
ASF_YT_CHANNEL_ID=
ASF_FB_PAGE_ID=
ASF_FB_PAGE_TOKEN=

# --- Session ---
# Jika kosong, bootstrap akan pakai fallback folder runtime yang sudah ada.
SESSION_SAVE_PATH=
